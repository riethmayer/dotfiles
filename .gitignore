.DS_Store

# Java
/stow/scripts/bin/apache-maven*
/stow/scripts/bin/google-java-format*

# Accidental keys
private.key
public.key

# Per-machine local overrides (the work-vs-private seam) — never shared.
# Carries machine identity (git user/email/signingkey), machine ids, and any
# secret references. Tracked `*.example` templates show what goes in each.
stow/git/.config/git/local
stow/zsh/.config/zsh/99_local.zsh

# pi rewrites its own settings.json with runtime state (lastChangelogVersion)
# on every update; the tracked settings.json.example carries the shared
# defaults, seeded by stow/bootstrap/.system-bootstrap.d/155_pi.sh.
stow/pi/.pi/agent/settings.json

# GPG
.gnupg/

# Google Cloud SDK (excluded - contains credentials)

# Claude plugins marketplaces (nested git repos)
stow/claude/.claude/plugins/marketplaces/

stow/gcloud/
stow/claude/.claude/plugins/installed_plugins.json
stow/claude/.claude/plugins/known_marketplaces.json
stow/claude/.claude/plugins/cache/
stow/claude/.claude/plugins/install-counts-cache.json
stow/claude/.claude/plugins/plugin-catalog-cache.json
stow/claude/.claude/plugins/.last_inuse_sweep
firebase-debug.log

# Claude runtime logs
.claudelog/

# Playwright MCP runtime artifacts (console logs, page snapshots)
.playwright-mcp/

# Python bytecode (skill-creator + any other Python skills)
__pycache__/
*.py[cod]

# Packaged skill build artifacts (scripts/package_skill.py output)
*.skill


# herdr runtime state — written next to config.toml if ~/.config/herdr ever
# gets stow-folded into the repo (install paths mkdir first, this is a belt).
stow/herdr/.config/herdr/*.log
stow/herdr/.config/herdr/*.sock
stow/herdr/.config/herdr/session.json
stow/herdr/.config/herdr/release-notes.json
# named-session runtime (herdr --session <name>) — same class as the files above
stow/herdr/.config/herdr/sessions/
# experimental pane_history snapshot — contains raw pane output (secrets!),
# must never be committed
stow/herdr/.config/herdr/session-history.json
# 0.7.5+ global plugin registry lockfile — runtime, not config
stow/herdr/.config/herdr/.plugins.lock

# per-machine seam files synced via 1Password (dotfiles-local-sync push/pull);
# tracked *.example templates stand in for them
stow/agents/Library/Application Support/Claude/claude_desktop_config.json
stow/claude/.claude/hooks/gh-pr-create-ship.sh
stow/claude/.claude/hooks/workos-billing-guard.sh
