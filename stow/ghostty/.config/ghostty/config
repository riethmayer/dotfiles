# Font
font-family = GeistMono Nerd Font Mono
font-size = 14

# Theme
theme = Dracula

# Window
window-decoration = false
macos-non-native-fullscreen = true

# Cursor
cursor-style = block
cursor-style-blink = true

# Mouse & Selection
copy-on-select = true
mouse-hide-while-typing = true

# Shell Integration
shell-integration = zsh

keybind = shift+enter=text:\x1b\r

# Cmd+T creates tmux window instead of ghostty tab
keybind = super+t=text:\x01c

# Cmd+N switches tmux windows (sends Alt+N, bound in tmux)
keybind = command+digit_1=text:\x1b1
keybind = command+digit_2=text:\x1b2
keybind = command+digit_3=text:\x1b3
keybind = command+digit_4=text:\x1b4
keybind = command+digit_5=text:\x1b5
keybind = command+digit_6=text:\x1b6
keybind = command+digit_7=text:\x1b7
keybind = command+digit_8=text:\x1b8
keybind = command+digit_9=text:\x1b9
