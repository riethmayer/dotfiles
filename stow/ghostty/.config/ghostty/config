# Font
font-family = GeistMono Nerd Font Mono
font-size = 14

# Theme (follows macOS appearance)
theme = light:GitHub Light Default,dark:Dracula

# Window
window-decoration = false
macos-non-native-fullscreen = true

# Cursor
cursor-style = block
cursor-style-blink = true
# Invert fg/bg of whatever cell the cursor is on — guarantees visibility
# regardless of theme or text color (overrides per-theme cursor-color).
cursor-invert-fg-bg = true

# Mouse & Selection
copy-on-select = true
mouse-hide-while-typing = true

# Shell Integration
shell-integration = zsh

keybind = shift+enter=text:\x1b\r

# Cmd+T new herdr space (sends prefix+c, bound in herdr)
keybind = super+t=text:\x01c

# Cmd+N jumps to herdr space N (sends prefix+shift+N as its punctuation char)
keybind = command+digit_1=text:\x01!
keybind = command+digit_2=text:\x01@
keybind = command+digit_3=text:\x01#
keybind = command+digit_4=text:\x01$
keybind = command+digit_5=text:\x01%
keybind = command+digit_6=text:\x01^
keybind = command+digit_7=text:\x01&
keybind = command+digit_8=text:\x01*
keybind = command+digit_9=text:\x01(

# Opt+N switches herdr tabs (sends Alt+N; digit keys only, Option stays
# free for special characters elsewhere)
keybind = alt+digit_1=text:\x1b1
keybind = alt+digit_2=text:\x1b2
keybind = alt+digit_3=text:\x1b3
keybind = alt+digit_4=text:\x1b4
keybind = alt+digit_5=text:\x1b5
keybind = alt+digit_6=text:\x1b6
keybind = alt+digit_7=text:\x1b7
keybind = alt+digit_8=text:\x1b8
keybind = alt+digit_9=text:\x1b9

# Cmd+w close herdr space with confirmation (sends Alt+w, bound in herdr)
keybind = super+w=text:\x1bw
