#!/usr/bin/env bash
# Stop hook - speaks summary via TTS when Claude finishes a task
# Toggle with: tts-on / tts-off

set -euo pipefail

STATE_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/claude-tts-enabled"

# Check if TTS is enabled
if [[ ! -f "$STATE_FILE" ]]; then
  echo '{"ok": true}'
  exit 0
fi

# Read hook input
HOOK_INPUT=$(cat)

# Avoid infinite loops - don't speak if already triggered by stop hook
STOP_ACTIVE=$(echo "$HOOK_INPUT" | jq -r '.stop_hook_active // false')
if [[ "$STOP_ACTIVE" == "true" ]]; then
  echo '{"ok": true}'
  exit 0
fi

# Extract the last assistant message as summary
TRANSCRIPT_PATH=$(echo "$HOOK_INPUT" | jq -r '.transcript_path // empty')

if [[ -z "$TRANSCRIPT_PATH" || ! -f "$TRANSCRIPT_PATH" ]]; then
  echo '{"ok": true}'
  exit 0
fi

# Get last assistant message (JSONL format - one JSON per line)
# Limit to ~500 chars for reasonable TTS length
SUMMARY=$(jq -rs '
  [.[] | select(.type == "assistant") | .message.content[]? | select(.type == "text") | .text]
  | last // "Task complete"
' "$TRANSCRIPT_PATH" 2>/dev/null | head -c 500)

# Skip if summary is too short or just tool usage
if [[ ${#SUMMARY} -lt 20 ]]; then
  echo '{"ok": true}'
  exit 0
fi

# Speak the summary in background
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
"$SCRIPT_DIR/tts-speak" "$SUMMARY" &>/dev/null &

echo '{"ok": true}'
