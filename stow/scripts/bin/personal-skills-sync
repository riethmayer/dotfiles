#!/bin/bash
#
# Keep Jan's personal skills repo available to Claude and Codex.
#
# The repo is the source of truth; dotfiles owns only setup and marketplace
# registration — agents install skills from the marketplace (duplicated per
# agent), no shared symlink. Normal runs clone or fast-forward when the
# checkout is clean. Dirty worktrees are fetched but never overwritten.

set -euo pipefail

MODE="full"
case "${1:-}" in
    "")
        ;;
    --pre-stow)
        MODE="pre-stow"
        ;;
    --git-only)
        MODE="git-only"
        ;;
    --check)
        MODE="check"
        ;;
    *)
        echo "Usage: personal-skills-sync [--pre-stow|--git-only|--check]" >&2
        exit 2
        ;;
esac

REPO_URL="${MY_SKILLS_REPO:-git@github.com:riethmayer/skills.git}"
REPO_REF="${MY_SKILLS_REF:-main}"
CODEX_MARKETPLACE_SOURCE="${MY_SKILLS_CODEX_MARKETPLACE_SOURCE:-git}"
SKILLS_REPO="${MY_SKILLS_DIR:-$HOME/src/my-skills}"
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles}"
SKILLS_DIR="$SKILLS_REPO/skills"
MARKETPLACE_JSON="$SKILLS_REPO/.agents/plugins/marketplace.json"
HOME_SKILLS="$HOME/.agents/skills"
DOTFILES_SKILLS="$DOTFILES_DIR/stow/agents/.agents/skills"

log() { printf '%s personal-skills-sync: %s\n' "$(date '+%Y-%m-%dT%H:%M:%S')" "$*"; }
die() { log "ERROR: $*" >&2; exit 1; }

is_dirty() {
    [ -n "$(git -C "$SKILLS_REPO" status --porcelain)" ]
}

ensure_repo() {
    mkdir -p "$(dirname "$SKILLS_REPO")"

    if [ -d "$SKILLS_REPO/.git" ]; then
        current_remote="$(git -C "$SKILLS_REPO" remote get-url origin 2>/dev/null || true)"
        if [ "$current_remote" != "$REPO_URL" ]; then
            log "origin is $current_remote, expected $REPO_URL; leaving checkout in place"
        fi

        git -C "$SKILLS_REPO" fetch --prune origin "$REPO_REF" || die "fetch failed for $REPO_URL"

        current_branch="$(git -C "$SKILLS_REPO" branch --show-current)"
        if is_dirty; then
            log "$SKILLS_REPO has local changes; fetched latest but skipped fast-forward"
        elif [ "$current_branch" = "$REPO_REF" ]; then
            git -C "$SKILLS_REPO" pull --ff-only origin "$REPO_REF" || die "fast-forward failed"
        else
            log "$SKILLS_REPO is on $current_branch, not $REPO_REF; fetched latest but skipped checkout"
        fi
    elif [ -e "$SKILLS_REPO" ]; then
        die "$SKILLS_REPO exists but is not a git checkout"
    else
        git clone --branch "$REPO_REF" "$REPO_URL" "$SKILLS_REPO" || die "clone failed for $REPO_URL"
    fi

    # Repo-local git hooks (pre-push bundle-version gate) live in .githooks;
    # hooksPath is per-clone config, so (re)set it on every sync.
    git -C "$SKILLS_REPO" config core.hooksPath .githooks

    [ -d "$SKILLS_DIR" ] || die "$SKILLS_DIR is missing"
    compgen -G "$SKILLS_DIR/*/SKILL.md" > /dev/null || die "$SKILLS_DIR does not look like the personal skills tree"
}

retire_home_symlink() {
    # ~/.agents/skills is retired entirely: every agent consumes skills via its
    # own marketplace/plugin install (duplicated content, per-machine choice of
    # bundles), never via a shared raw-skill symlink. Remove the old link; a
    # real directory means skill content drifted outside the repo — refuse.
    if [ -L "$HOME_SKILLS" ]; then
        rm "$HOME_SKILLS"
        log "removed retired ~/.agents/skills symlink"
    elif [ -e "$HOME_SKILLS" ]; then
        die "$HOME_SKILLS is a real path — move its contents into $SKILLS_DIR and remove it"
    fi
}

ensure_codex_marketplace() {
    command -v codex >/dev/null 2>&1 || {
        log "codex CLI not found; skipping Codex marketplace registration"
        return
    }

    [ -f "$MARKETPLACE_JSON" ] || die "$MARKETPLACE_JSON is missing; Codex marketplace generation has not run"

    if [ "$CODEX_MARKETPLACE_SOURCE" = "local" ]; then
        desired_source="$SKILLS_REPO"
    elif [ "$CODEX_MARKETPLACE_SOURCE" = "git" ]; then
        desired_source="$REPO_URL"
    else
        die "unsupported MY_SKILLS_CODEX_MARKETPLACE_SOURCE=$CODEX_MARKETPLACE_SOURCE"
    fi

    current_root="$(codex plugin marketplace list | awk '$1 == "jan-skills" { print $2; exit }')"
    if [ -n "$current_root" ]; then
        if [ "$CODEX_MARKETPLACE_SOURCE" = "local" ] && [ "$current_root" = "$SKILLS_REPO" ]; then
            log "Codex marketplace jan-skills already points at $SKILLS_REPO"
            return
        fi
        if [ "$CODEX_MARKETPLACE_SOURCE" = "git" ] && [ "$current_root" != "$SKILLS_REPO" ]; then
            log "Codex marketplace jan-skills already registered ($current_root)"
            upgrade_codex_marketplace
            return
        fi
        codex plugin marketplace remove jan-skills
    fi

    if [ "$CODEX_MARKETPLACE_SOURCE" = "local" ]; then
        codex plugin marketplace add "$desired_source"
    else
        codex plugin marketplace add "$desired_source" --ref "$REPO_REF"
    fi
    log "registered Codex marketplace jan-skills from $desired_source"
}

upgrade_codex_marketplace() {
    command -v codex >/dev/null 2>&1 || return
    codex plugin marketplace list | awk '$1 == "jan-skills" { found=1 } END { exit found ? 0 : 1 }' || return

    current_root="$(codex plugin marketplace list | awk '$1 == "jan-skills" { print $2; exit }')"
    if [ "$current_root" != "$SKILLS_REPO" ]; then
        codex plugin marketplace upgrade jan-skills || die "Codex marketplace upgrade failed"
        log "upgraded Codex marketplace jan-skills"
    fi
}

check_state() {
    [ -d "$SKILLS_REPO/.git" ] || die "$SKILLS_REPO is not cloned"
    [ -d "$SKILLS_DIR" ] || die "$SKILLS_DIR is missing"
    # No skills-reachable path may exist inside the dotfiles repo (see
    # ensure_home_symlink); both former in-repo symlinks are retired.
    [ ! -e "$DOTFILES_SKILLS" ] || die "$DOTFILES_SKILLS is retired — remove it (skills must not be reachable inside the dotfiles tree)"
    # Claude loads personal skills via the enabled jan-* plugins, not a
    # ~/.claude/skills symlink (retired to avoid double-loading).
    [ ! -L "$HOME/.claude/skills" ] || die "~/.claude/skills symlink is retired — remove it (skills load via jan-* plugins)"
    # ~/.agents/skills is retired too: agents install skills via marketplaces.
    [ ! -e "$HOME_SKILLS" ] || die "~/.agents/skills is retired — remove it (skills install via each agent's marketplace)"
    if command -v codex >/dev/null 2>&1; then
        codex plugin marketplace list | awk '$1 == "jan-skills" { found=1 } END { exit found ? 0 : 1 }' || die "Codex marketplace jan-skills is not registered"
        plugin_list="$(mktemp)"
        codex plugin list > "$plugin_list" || {
            rm -f "$plugin_list"
            die "Codex plugin list failed"
        }
        grep -q '^jan-[a-z-]*@jan-skills' "$plugin_list" || {
            rm -f "$plugin_list"
            die "Codex cannot see generated jan-skills plugins"
        }
        # With ~/.agents/skills retired, installed plugins are Codex's only
        # skill source — at least one bundle must be installed per machine.
        grep -E '^jan-[a-z-]*@jan-skills[[:space:]]+installed' "$plugin_list" > /dev/null || {
            rm -f "$plugin_list"
            die "no jan-skills plugin installed — pick this machine's bundles with 'codex plugin add <bundle>@jan-skills'"
        }
        rm -f "$plugin_list"
    fi
    log "OK"
}

case "$MODE" in
    check)
        check_state
        ;;
    pre-stow)
        ensure_repo
        retire_home_symlink
        ;;
    git-only)
        ensure_repo
        upgrade_codex_marketplace
        ;;
    full)
        ensure_repo
        retire_home_symlink
        ensure_codex_marketplace
        ;;
esac
