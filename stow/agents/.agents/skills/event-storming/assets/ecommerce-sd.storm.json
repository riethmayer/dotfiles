{
  "title": "Online Shop — Software-Design Event Storm",
  "subtitle": "Process-Modeling chain + aggregates (yellow bands) wrapping the events of each state machine.",
  "happy_path": [
    {"kind": "actor",   "label": "Shopper"},
    {"kind": "command", "label": "Add to Cart"},
    {"kind": "event",   "label": "Item Added to Cart", "aggregate": "Cart"},
    {"kind": "event",   "label": "Cart Items Frozen",  "aggregate": "Cart"},
    {"kind": "read",    "label": "Cart Summary"},

    {"kind": "command", "label": "Begin Checkout"},
    {"kind": "event",   "label": "Checkout Started",   "aggregate": "Checkout"},
    {"kind": "command", "label": "Submit Address"},
    {"kind": "system",  "label": "Address Validation"},
    {"kind": "event",   "label": "Address Validated",  "aggregate": "Checkout"},
    {"kind": "command", "label": "Authorize Payment"},
    {"kind": "system",  "label": "Stripe"},
    {"kind": "event",   "label": "Payment Authorized", "aggregate": "Payment"},

    {"kind": "command", "label": "Place Order"},
    {"kind": "event",   "label": "Order Placed",              "aggregate": "Order"},
    {"kind": "policy",  "label": "On placed → fan out"},
    {"kind": "event",   "label": "Inventory Reserved",        "aggregate": "Order"},
    {"kind": "event",   "label": "Order Confirmation Sent",   "aggregate": "Order"},
    {"kind": "system",  "label": "SendGrid"},

    {"kind": "actor",   "label": "Warehouse Op"},
    {"kind": "command", "label": "Dispatch Shipment"},
    {"kind": "event",   "label": "Shipment Dispatched", "aggregate": "Shipment"},
    {"kind": "event",   "label": "Payment Captured",    "aggregate": "Payment"},
    {"kind": "policy",  "label": "Capture on ship"},
    {"kind": "system",  "label": "DHL"},
    {"kind": "event",   "label": "Delivery Confirmed",  "aggregate": "Shipment", "outcome": "happy"}
  ],
  "branches": [
    {
      "from": 12,
      "label": "Payment refused",
      "beats": [
        {"kind": "event",   "label": "Payment Declined",  "aggregate": "Payment", "outcome": "sad"},
        {"kind": "policy",  "label": "On declined → release auth, keep cart"},
        {"kind": "hotspot", "label": "3DS step-up?"}
      ]
    },
    {
      "from": 16,
      "label": "Out of stock",
      "beats": [
        {"kind": "event",   "label": "Out of Stock",      "aggregate": "Order"},
        {"kind": "policy",  "label": "On OOS → cancel + refund"},
        {"kind": "event",   "label": "Order Cancelled",   "aggregate": "Order", "outcome": "sad"}
      ]
    },
    {
      "from": 25,
      "label": "Return path",
      "beats": [
        {"kind": "actor",   "label": "Customer"},
        {"kind": "command", "label": "Open Return"},
        {"kind": "event",   "label": "Return Requested",  "aggregate": "Return"},
        {"kind": "event",   "label": "Return Received",   "aggregate": "Return"},
        {"kind": "event",   "label": "Refund Issued",     "aggregate": "Return", "outcome": "happy"}
      ]
    }
  ]
}
