{
  "title": "Online Shop — Process-Modeling Event Storm",
  "subtitle": "Each happy-path moment becomes a chain: actor → command → event → policy. Branches below explore the alternatives.",
  "happy_path": [
    {"kind": "actor",   "label": "Shopper"},
    {"kind": "command", "label": "Add to Cart"},
    {"kind": "event",   "label": "Item Added to Cart"},
    {"kind": "event",   "label": "Cart Items Frozen"},
    {"kind": "read",    "label": "Cart Summary"},

    {"kind": "command", "label": "Begin Checkout"},
    {"kind": "event",   "label": "Checkout Started"},
    {"kind": "read",    "label": "Checkout Wizard"},

    {"kind": "command", "label": "Submit Address"},
    {"kind": "system",  "label": "Address Validation"},
    {"kind": "event",   "label": "Address Validated"},

    {"kind": "command", "label": "Authorize Payment"},
    {"kind": "system",  "label": "Stripe"},
    {"kind": "event",   "label": "Payment Authorized"},

    {"kind": "command", "label": "Place Order"},
    {"kind": "event",   "label": "Order Placed"},
    {"kind": "policy",  "label": "On placed → fan out"},
    {"kind": "event",   "label": "Inventory Reserved"},
    {"kind": "event",   "label": "Order Confirmation Sent"},
    {"kind": "system",  "label": "SendGrid"},

    {"kind": "actor",   "label": "Warehouse Op"},
    {"kind": "command", "label": "Dispatch Shipment"},
    {"kind": "event",   "label": "Shipment Dispatched"},
    {"kind": "event",   "label": "Payment Captured"},
    {"kind": "policy",  "label": "Capture on ship"},

    {"kind": "system",  "label": "DHL"},
    {"kind": "event",   "label": "Delivery Confirmed"},
    {"kind": "event",   "label": "Customer Happy", "outcome": "happy"}
  ],
  "branches": [
    {
      "from": 2,
      "label": "Cart timeout",
      "beats": [
        {"kind": "policy",  "label": "After 15min idle → release"},
        {"kind": "event",   "label": "Cart Items Released", "outcome": "sad"},
        {"kind": "hotspot", "label": "Re-add or extend?"}
      ]
    },
    {
      "from": 10,
      "label": "Bad address",
      "beats": [
        {"kind": "event",   "label": "Address Validation Failed"},
        {"kind": "policy",  "label": "On invalid → suggest correction"},
        {"kind": "hotspot", "label": "How many retries?"}
      ]
    },
    {
      "from": 13,
      "label": "Payment refused",
      "beats": [
        {"kind": "event",   "label": "Payment Declined", "outcome": "sad"},
        {"kind": "policy",  "label": "On declined → keep cart, retry"},
        {"kind": "hotspot", "label": "3DS step-up vs hard decline?"}
      ]
    },
    {
      "from": 17,
      "label": "Out of stock",
      "beats": [
        {"kind": "event",   "label": "Out of Stock"},
        {"kind": "policy",  "label": "On OOS → cancel + refund"},
        {"kind": "event",   "label": "Order Cancelled", "outcome": "sad"},
        {"kind": "hotspot", "label": "Partial fulfillment?"}
      ]
    },
    {
      "from": 27,
      "label": "Return path",
      "beats": [
        {"kind": "actor",   "label": "Customer"},
        {"kind": "command", "label": "Open Return"},
        {"kind": "event",   "label": "Return Requested"},
        {"kind": "event",   "label": "Return Received"},
        {"kind": "policy",  "label": "On received → inspect"},
        {"kind": "event",   "label": "Refund Issued", "outcome": "happy"},
        {"kind": "hotspot", "label": "30-day window?"}
      ]
    }
  ]
}
