{
  "agentic-prompt": {
    "prefix": "agp",
    "description": "Claude Code slash command frontmatter",
    "body": [
      "---",
      "model: opus|sonnet|haiku",
      "description: description",
      "argument-hint: [arg1] [arg2]",
      "allowed-tools: Task, TaskOutput, Bash, Glob, Grep, Read, Edit, Write, NotebookEdit, WebFetch, TodoWrite, WebSearch, KillShell, AskUserQuestion, Skill, EnterPlanMode, ExitPlanMode",
      "context: fork|none|inherit",
      "agent: general-purpose|Explore|Plan",
      "disable-model-invocation: false|true",
      "skills:",
      "  - skill-name",
      "hooks:",
      "  PreToolUse:",
      "    - matcher: tool-name",
      "      hooks:",
      "        - type: command",
      "          command: $CLAUDE_PROJECT_DIR/.claude/hooks/hook-script.sh",
      "          once: true|false",
      "  PostToolUse:",
      "    - matcher: tool-name-or-pattern",
      "      hooks:",
      "        - type: command",
      "          command: shell-command",
      "          once: true|false",
      "  Stop:",
      "    - hooks:",
      "        - type: command",
      "          command: shell-command",
      "          once: true|false",
      "---",
      "",
      "# Purpose",
      "",
      "description",
      "",
      "## Variables",
      "",
      "<!-- Docs: https://docs.anthropic.com/en/docs/claude-code/hooks -->",
      "",
      "**Environment:**",
      "- `$CLAUDE_PROJECT_DIR` - project root",
      "- `$CLAUDE_ENV_FILE` - persist env vars (SessionStart/Setup only)",
      "- `$CLAUDE_CODE_REMOTE` - \"true\" if web, empty if CLI",
      "",
      "**Stdin JSON (all hooks):**",
      "- `session_id`, `transcript_path`, `cwd`, `permission_mode`, `hook_event_name`",
      "",
      "**Tool hooks (PreToolUse/PostToolUse):**",
      "- `tool_name`, `tool_input`, `tool_use_id`",
      "- `tool_response` (PostToolUse only)",
      "",
      "",
      "## Codebase Structure",
      "",
      "",
      "",
      "## Instructions",
      "",
      "",
      "",
      "## Workflow",
      "",
      "",
      "",
      "## Report",
      "",
      "",
      ""
    ]
  },
  "agentic-agent": {
    "prefix": "aga",
    "description": "Claude Code subagent definition",
    "body": [
      "---",
      "name: lowercase-with-hyphens",
      "description: when to delegate to this subagent",
      "tools: Read, Glob, Grep, Bash, Edit, Write, Task, WebFetch, WebSearch",
      "disallowedTools: tools-to-deny",
      "model: sonnet|opus|haiku|inherit",
      "permissionMode: default|acceptEdits|dontAsk|bypassPermissions|plan",
      "skills:",
      "  - skill-name",
      "hooks:",
      "  PreToolUse:",
      "    - matcher: tool-name",
      "      hooks:",
      "        - type: command",
      "          command: $CLAUDE_PROJECT_DIR/.claude/hooks/hook-script.sh",
      "  PostToolUse:",
      "    - matcher: tool-name-or-pattern",
      "      hooks:",
      "        - type: command",
      "          command: shell-command",
      "  Stop:",
      "    - hooks:",
      "        - type: command",
      "          command: shell-command",
      "---",
      "",
      "<!-- Docs: https://docs.anthropic.com/en/docs/claude-code/sub-agents -->",
      "",
      "# Role",
      "",
      "what this agent is and does",
      "",
      "# Capabilities",
      "",
      "what tools and skills it has access to",
      "",
      "# Instructions",
      "",
      "step-by-step guidance",
      "",
      "# Output Format",
      "",
      "expected response structure",
      ""
    ]
  }
}
