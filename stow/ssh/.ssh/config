Include /Users/jan/.ssh/conductor_config

# SSH agent: default macOS ssh-agent (Keychain). Keys auto-add to the agent on
# first use via the `Host *` block below, so git signing + auth survive a reboot
# without a manual ssh-add. (One-time seed if the agent is empty right now:
# ssh-add --apple-use-keychain ~/.ssh/id_ed25519)
#
# (Previously routed through 1Password's agent socket; reverted because
# op-ssh-sign was failing intermittently for git commit signing.)

Host *
  IgnoreUnknown UseKeychain
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/id_ed25519
