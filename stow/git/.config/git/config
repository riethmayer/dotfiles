[push]
  default = current
  autoSetupRemote = true
[alias]
  co = checkout
  st = status
  br = branch
  who = shortlog -s --
  df = diff
  ci = commit
  lg = log --oneline --decorate --all --graph
  s = status -s
  g = grep --extended-regexp --break --heading --line-number
  up = !git fetch origin && git rebase origin/main
  down = !git checkout main && git merge @{1} --ff-only
  score = !git log --pretty=format:%an | sort | uniq -ci | sort -r
  find-change = "!f() { git log --reverse --patch --pickaxe-all -S \"$1\" ; }; f"
  hide   = update-index --assume-unchanged
  unhide = update-index --no-assume-unchanged
  undo = reset --soft HEAD^
[user]
  name = Jan Riethmayer
	email = jan@earlybird.com
	signingkey = ssh-rsa 
[hub]
  protocol = https
[color]
	ui = true
[core]
  autocrlf = input
  line-numbers = true
  pager = delta
[pull]
	rebase = true
[rerere]
	enabled = true
[init]
	defaultBranch = main
[commit]
	gpgsign = true
[gpg]
	program = gpg
	format = ssh
  # GPG program will be found in PATH (works for both Intel and ARM Macs)

[coderabbit]
	machineId = cli/3cce15a84a4547f8935b5b09d2aa7f3e
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
