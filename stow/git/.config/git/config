[push]
  default = current
  autoSetupRemote = true
[alias]
  co = checkout
  st = status
  br = branch
  who = shortlog -s --
  df = diff
  ci = commit
  lg = log --oneline --decorate --all --graph
  s = status -s
  g = grep --extended-regexp --break --heading --line-number
  up = !git fetch origin && git rebase origin/main
  down = !git checkout main && git merge @{1} --ff-only
  score = !git log --pretty=format:%an | sort | uniq -ci | sort -r
  find-change = "!f() { git log --reverse --patch --pickaxe-all -S \"$1\" ; }; f"
  hide   = update-index --assume-unchanged
  unhide = update-index --no-assume-unchanged
  undo = reset --soft HEAD^
[hub]
  protocol = https
[color]
	ui = true
[core]
  autocrlf = input
  line-numbers = true
  pager = delta
[pull]
	rebase = true
[rerere]
	enabled = true
[init]
	defaultBranch = main
[commit]
	gpgsign = true
[gpg]
	program = gpg
	format = ssh
  # GPG program will be found in PATH (works for both Intel and ARM Macs)
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential

# Per-machine identity & machine-specific settings live in an untracked file.
# See local.example. Loaded last, so it overrides anything above.
# Never commit ~/.config/git/local — it carries the work-vs-private identity
# (user.email/signingkey), the coderabbit machineId, and absolute home paths.
[include]
	path = ~/.config/git/local
