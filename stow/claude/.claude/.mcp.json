{
  "mcpServers": {
    "mise": {
      "command": "mise",
      "args": ["mcp"],
      "env": {
        "MISE_EXPERIMENTAL": "1"
      }
    },
    "playwright": {
      "command": "bash",
      "args": [
        "-c",
        "dotenvx run -f ~/.env -- npx @playwright/mcp@latest --cdp-endpoint \"wss://cloud.lightpanda.io/v1?token=$LIGHTPANDA_API_KEY\""
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "excalidraw": {
      "command": "node",
      "args": ["/Users/jan/code/excalidraw-mcp/dist/index.js", "--stdio"]
    }
  }
}
